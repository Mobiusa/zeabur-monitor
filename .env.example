PORT=3000

# 账号 Token 加密密钥（强烈推荐设置）
# 运行 node generate-secret.js 生成 64 位十六进制密钥
# 设置后，账号的 API Token 将使用 AES-256-GCM 加密存储
ACCOUNTS_SECRET=

# 多设备同步账号配置（可选）
# 如果配置了此环境变量，所有设备访问时都会自动加载这些账号
# 格式: 账号名称:API_TOKEN
# 多个账号用逗号分隔
# 示例: ACCOUNTS=主账号:sk-xxxxxx,备用账号:sk-yyyyyy
ACCOUNTS=

# =========================================================
# 配置存储后端（默认 file，可选 file/webdav/s3/mysql）
# =========================================================
CONFIG_BACKEND=file

# file 模式：默认写入 ./config.json（推荐挂载到持久卷）
CONFIG_FILE_PATH=

# webdav 模式
WEBDAV_URL=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
WEBDAV_TIMEOUT_MS=10000

# s3 模式（兼容 AWS S3 / R2 / MinIO）
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_KEY=zmon/config.json
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# mysql 模式（优先使用 MYSQL_URL；否则使用分项配置）
MYSQL_URL=
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_TABLE=zmon_config
MYSQL_CONNECTION_LIMIT=5

# =========================================================
# 稳定性与性能参数
# =========================================================
CONFIG_CACHE_TTL_MS=5000
GRAPHQL_TIMEOUT_MS=10000
GRAPHQL_RETRY_MAX=2
ACCOUNT_FETCH_CONCURRENCY=4
